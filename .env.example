# ─────────────────────────────────────────────────────────────
# CommentSense Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Meta / Instagram ──────────────────────────────────────────
# Get these from developers.facebook.com → Your App → App Settings → Basic
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# Must match exactly what you set in the Meta Developer console
# For local dev: http://localhost:8000/auth/callback
REDIRECT_URI=http://localhost:8000/auth/callback

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
# Local dev example: postgresql+asyncpg://postgres:password@localhost:5432/commentsense
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/commentsense

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Debug ─────────────────────────────────────────────────────
# Set to "true" in development only — exposes error details in API responses
EXPOSE_ERROR_DETAILS=false
